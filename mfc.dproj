<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{8F5B6A1C-3D2E-4F7B-9A8D-1E2F3C4B5A6D}</ProjectGuid>
    <MainSource>mfc.dpr</MainSource>
    <Config Condition="'$(Config)'==''">Debug</Config>
    <Platform Condition="'$(Platform)'==''">Win32</Platform>
    <Target>Win32</Target>
    <AppType>Console</AppType>
    <DCC_DCCCompiler>dcc32</DCC_DCCCompiler>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Debug'">
    <DCC_Define>DEBUG</DCC_Define>
    <DCC_Optimize>false</DCC_Optimize>
    <DCC_DebugInfoInExe>true</DCC_DebugInfoInExe>
    <DCC_MapFile>3</DCC_MapFile>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Release'">
    <DCC_Define>RELEASE</DCC_Define>
    <DCC_Optimize>true</DCC_Optimize>
    <DCC_DebugInfoInExe>false</DCC_DebugInfoInExe>
    <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
  </PropertyGroup>
  <ItemGroup>
    <DelphiCompile Include="mfc.dpr">
      <MainSource>MainSource</MainSource>
    </DelphiCompile>
    <DCCReference Include="Source\MF.Migrator.CLI.pas"/>
    <DCCReference Include="Source\MF.Migrator.API.pas"/>
  </ItemGroup>
  <Import Project="$(BDS)\Bin\CodeGear.Common.Targets"/>
  <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets"/>
</Project>
